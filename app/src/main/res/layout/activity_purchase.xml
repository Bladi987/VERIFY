<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:fitsSystemWindows="true"
    android:background="#F8F9FA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeaderCompra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/white_pure"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilProveedor"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="Seleccionar Proveedor"
            app:startIconDrawable="@drawable/ic_business"
            app:layout_constraintTop_toTopOf="parent">

            <AutoCompleteTextView
                android:id="@+id/etBuscarProveedor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilBuscarCompra"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="4dp"
            android:hint="Buscar producto para stock..."
            app:startIconDrawable="@drawable/ic_search"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_delete"
            app:layout_constraintEnd_toStartOf="@+id/btnScannerCompra"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilProveedor">

            <AutoCompleteTextView
                android:id="@+id/etBuscarCompra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:maxLines="1"
                android:singleLine="true"/>
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnScannerCompra"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_button_green"
            android:elevation="2dp"
            android:rotationY="180"
            android:src="@drawable/ic_barcode_read"
            app:layout_constraintBottom_toBottomOf="@+id/tilBuscarCompra"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tilBuscarCompra"
            app:tint="@color/white_pure" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPurchase"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        tools:listitem="@layout/item_purchase"
        app:layout_constraintBottom_toTopOf="@+id/cardResumenCompra"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderCompra" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResumenCompra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.TopRounded">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Inversión"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvTotalCompra"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="S/ 0.00"
                    android:textColor="#2E7D32"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinalizarCompra"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="REGISTRAR COMPRA"
                android:textSize="16sp"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>