<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPurchase"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvIdCompra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#C-001"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="15/03/2026 18:20"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/tvIdCompra"
            app:layout_constraintTop_toTopOf="@id/tvIdCompra" />

        <TextView
            android:id="@+id/tvEstadoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_green"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="COMPLETADO"
            android:textColor="@color/white_pure"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvProveedorNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Distribuidora Global S.A.C."
            android:textColor="@color/grey_text_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvTotalCompra"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvIdCompra" />

        <TextView
            android:id="@+id/tvEmpleadoNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Realizado por: Juan Perez"
            android:textColor="#757575"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvProveedorNombre" />

        <TextView
            android:id="@+id/tvTotalCompra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="S/ 1,250.00"
            android:textColor="#2E7D32"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvProveedorNombre" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>